# Anthropic (Intelligence Console live query endpoint)
ANTHROPIC_API_KEY=

# Google Calendar booking (see src/lib/google-calendar.ts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://xeedly.com/api/auth/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_REFRESH_TOKEN=

# Timezone for booking slot generation (IANA name).
BOOKING_TIMEZONE=America/Denver

# Cloudflare Turnstile (bot protection for public forms)
# Get keys at https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
